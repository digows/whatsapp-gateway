# .env (Do not commit to git)
RESIDENTIAL_PROXY_URL=
POSTGRES_URL=postgresql://whatsapp-gateway:whatsapp-gateway@localhost:5432/whatsapp-gateway
DB_SCHEMA=public
REDIS_URL=redis://localhost:6379
NATS_URL=nats://nats:nats@localhost:4222
LOG_LEVEL=debug
BAILEYS_LOG_LEVEL=warn
MAX_CONCURRENT_SESSIONS=50
DISABLE_REDLOCK=false
SESSION_LOCK_TTL_MS=120000
SESSION_LOCK_HEARTBEAT_MS=45000
