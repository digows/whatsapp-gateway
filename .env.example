# .env.example
# This file serves as a template for required environment variables.
# Copy it to `.env` and fill it with real development values.

# [RESIDENTIAL PROXY]
# Expected format: http://user:password@host:port
# Leave blank in development to use your local native IP (direct connection).
RESIDENTIAL_PROXY_URL=

# [PROVIDER ID]
# Logical identifier carried by sessions, subjects and telemetry.
CHANNEL_PROVIDER_ID=whatsapp-web

# [DATABASE]
# PostgreSQL connection string for persistent AuthState storage
POSTGRES_URL=postgresql://user:pass@localhost:5432/whatsapp_gateway
POSTGRES_SSL_ENABLED=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_SSL_CA=

# [CACHE & LOCKS]
# Redis connection string for fast AuthState reads and distributed concurrency locking
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=wa
REDIS_KEY_SESSION_LOCK_TEMPLATE={prefix}:{workspaceId}:lock:session:{sessionId}
REDIS_KEY_SESSION_WORKER_REGISTRY_TEMPLATE={prefix}:{workspaceId}:registry:workers
REDIS_KEY_CLUSTER_ALIVE_TEMPLATE={prefix}:cluster:alive:{workerId}
REDIS_KEY_CLUSTER_HEALTH_TEMPLATE={prefix}:cluster:health
REDIS_KEY_AUTH_RECORD_TEMPLATE={prefix}:{workspaceId}:auth:{sessionId}:{type}:{id}
REDIS_KEY_AUTH_SESSION_PATTERN_TEMPLATE={prefix}:{workspaceId}:auth:{sessionId}:*
REDIS_KEY_LID_MAPPING_TEMPLATE={prefix}:{workspaceId}:lid-mapping:{jid}
REDIS_KEY_ANTI_BAN_WARMUP_TEMPLATE={prefix}:{provider}:{workspaceId}:antiban:warmup:{sessionId}
REDIS_KEY_COMMAND_PROCESSING_TEMPLATE={prefix}:{provider}:{workspaceId}:command:processing:{sessionId}:{kind}:{identifier}
REDIS_KEY_COMMAND_COMPLETED_TEMPLATE={prefix}:{provider}:{workspaceId}:command:completed:{sessionId}:{kind}:{identifier}
REDIS_COMMAND_PROCESSING_TTL_SECONDS=600
REDIS_COMMAND_COMPLETED_TTL_SECONDS=604800

# [MESSAGING BROKER]
# NATS server connection URL
NATS_URL=nats://localhost:4222
NATS_MODE=ephemeral
NATS_JETSTREAM_STREAM_NAME=gateway_v1
NATS_JETSTREAM_STORAGE=file
NATS_JETSTREAM_REPLICAS=1
NATS_JETSTREAM_MAX_AGE_MS=604800000
NATS_JETSTREAM_DUPLICATE_WINDOW_MS=120000
NATS_JETSTREAM_ACK_WAIT_MS=30000
NATS_JETSTREAM_MAX_DELIVER=10
NATS_SUBJECT_CONTROL_TEMPLATE=gateway.v1.channel.{provider}.worker.{workerId}.control
NATS_SUBJECT_INBOUND_TEMPLATE=gateway.v1.channel.{provider}.session.{workspaceId}.{sessionId}.incoming
NATS_SUBJECT_OUTBOUND_TEMPLATE=gateway.v1.channel.{provider}.session.{workspaceId}.{sessionId}.outgoing
NATS_SUBJECT_DELIVERY_TEMPLATE=gateway.v1.channel.{provider}.session.{workspaceId}.{sessionId}.delivery
NATS_SUBJECT_STATUS_TEMPLATE=gateway.v1.channel.{provider}.session.{workspaceId}.{sessionId}.status
NATS_SUBJECT_ACTIVATION_TEMPLATE=gateway.v1.channel.{provider}.session.{workspaceId}.{sessionId}.activation

# [HTTP API]
# Synchronous API bind used for activation and future operational resources
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# [DEV ENTRYPOINT]
# Used only by `src/dev.ts` / `npm run dev`
DEV_WORKSPACE_ID=1
DEV_SESSION_ID=local-onboarding-session

# [LOGGING]
# Options: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info
BAILEYS_LOG_LEVEL=warn

# [SCALING]
# Maximum concurrent sessions per worker pod
MAX_CONCURRENT_SESSIONS=50
DISABLE_REDLOCK=false
SESSION_LOCK_TTL_MS=120000
SESSION_LOCK_HEARTBEAT_MS=45000

# [ANTI-BAN]
# Outbound protection layer
ANTI_BAN_ENABLED=true
ANTI_BAN_MIN_DELAY_MS=1500
ANTI_BAN_MAX_DELAY_MS=5000
ANTI_BAN_NEW_CHAT_DELAY_MS=3000
ANTI_BAN_MAX_COOLDOWN_MS=120000
ANTI_BAN_BURST_ALLOWANCE=3
ANTI_BAN_MAX_PER_MINUTE=8
ANTI_BAN_MAX_PER_HOUR=200
ANTI_BAN_MAX_PER_DAY=1500
ANTI_BAN_MAX_IDENTICAL_MESSAGES=3
ANTI_BAN_ZERO_WIDTH_VARIATION_ENABLED=true
ANTI_BAN_PUNCTUATION_VARIATION_ENABLED=false
ANTI_BAN_WARMUP_ENABLED=true
ANTI_BAN_WARMUP_DAYS=7
ANTI_BAN_WARMUP_DAY1_LIMIT=60
ANTI_BAN_WARMUP_GROWTH_FACTOR=1.6
ANTI_BAN_WARMUP_INACTIVITY_THRESHOLD_HOURS=168
ANTI_BAN_WARMUP_MISSING_STATE_MODE=graduated
ANTI_BAN_WARMUP_STATE_TTL_SECONDS=15552000
ANTI_BAN_HEALTH_DISCONNECT_WARNING_THRESHOLD=3
ANTI_BAN_HEALTH_DISCONNECT_CRITICAL_THRESHOLD=5
ANTI_BAN_HEALTH_FAILED_MESSAGE_THRESHOLD=5
ANTI_BAN_LOG_RISK_CHANGES=true
ANTI_BAN_AUTO_PAUSE_AT=critical
